<Window x:Class="TmnfDedimaniaScraper.RecordsDisplaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Show Records Settings"
        Width="400"
        Height="540"
        MinWidth="360"
        MinHeight="420"
        WindowStartupLocation="Manual"
        Background="#0F172A"
        Foreground="#E5E7EB"
        Icon="pack://application:,,,/Assets/f1_app_icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#243244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
        </Style>
        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="TabButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="SubLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionLabelStyle}">
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="8" Grid.IsSharedSizeScope="True">
            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblMain"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblA"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValA"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblB"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValB"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="record count:" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox x:Name="ShowCountTextBox" Grid.Column="4" Width="54" Style="{StaticResource CompactTextBoxStyle}" TextChanged="ShowCountTextBox_TextChanged"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblMain"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblA"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValA"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="title size:" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox x:Name="TitleSizeTextBox" Grid.Column="4" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>

                    <TextBlock Grid.Row="2" Text="text size:" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox x:Name="FontSizeTextBox" Grid.Row="2" Grid.Column="4" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>

                    <TextBlock Grid.Row="4" Text="text weight:" Style="{StaticResource SectionLabelStyle}"/>
                    <ComboBox x:Name="FontWeightComboBox" Grid.Row="4" Grid.Column="4" Width="92" Style="{StaticResource CompactComboBoxStyle}">
                        <ComboBoxItem Content="Normal"/>
                        <ComboBoxItem Content="Bold"/>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblMain"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValA"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValB"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValC"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="position" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBlock Grid.Column="2" Text="x:" Style="{StaticResource SubLabelStyle}"/>
                    <TextBox x:Name="WindowLeftTextBox" Grid.Column="4" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>
                    <TextBlock Grid.Column="6" Text="y:" Style="{StaticResource SubLabelStyle}"/>
                    <TextBox x:Name="WindowTopTextBox" Grid.Column="8" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>

                    <TextBlock Grid.Row="2" Text="size" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="x:" Style="{StaticResource SubLabelStyle}"/>
                    <TextBox x:Name="WindowWidthTextBox" Grid.Row="2" Grid.Column="4" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="6" Text="y:" Style="{StaticResource SubLabelStyle}"/>
                    <TextBox x:Name="WindowHeightTextBox" Grid.Row="2" Grid.Column="8" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>

                    <TextBlock Grid.Row="4" Text="spacing" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="ver:" Style="{StaticResource SubLabelStyle}"/>
                    <TextBox x:Name="VerticalSpacingTextBox" Grid.Row="4" Grid.Column="4" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="6" Text="rank:" Style="{StaticResource SubLabelStyle}"/>
                    <TextBox x:Name="RankTimeSpacingTextBox" Grid.Row="4" Grid.Column="8" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="10" Text="time:" Style="{StaticResource SubLabelStyle}"/>
                    <TextBox x:Name="TimeBySpacingTextBox" Grid.Row="4" Grid.Column="12" Width="54" Style="{StaticResource CompactTextBoxStyle}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblMain"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblA"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValA"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="background color:" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox x:Name="BackgroundColorTextBox" Grid.Column="4" Width="110" Style="{StaticResource CompactTextBoxStyle}"/>
                    <Button x:Name="PickBackgroundColorButton" Grid.Column="6" Width="50" Style="{StaticResource SmallButtonStyle}" Content="pick" Click="PickBackgroundColorButton_Click"/>

                    <TextBlock Grid.Row="2" Text="background opacity:" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox x:Name="BackgroundOpacityTextBox" Grid.Row="2" Grid.Column="4" Width="70" Style="{StaticResource CompactTextBoxStyle}"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblMain"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValA"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Table:" Style="{StaticResource SectionLabelStyle}"/>
                    <StackPanel Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <Button x:Name="Table1TabButton" Style="{StaticResource TabButtonStyle}" Content="table 1" Click="Table1TabButton_Click"/>
                        <Button x:Name="Table2TabButton" Style="{StaticResource TabButtonStyle}" Margin="0" Content="table 2" Click="Table2TabButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Item:" Style="{StaticResource SectionLabelStyle}"/>
                    <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <Button x:Name="RankItemTabButton" Style="{StaticResource TabButtonStyle}" Content="rank" Click="RankItemTabButton_Click"/>
                        <Button x:Name="TimeItemTabButton" Style="{StaticResource TabButtonStyle}" Margin="0" Content="time" Click="TimeItemTabButton_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Text="Record slot:" Style="{StaticResource SectionLabelStyle}"/>
                    <ComboBox x:Name="TargetSlotComboBox" Grid.Row="4" Grid.Column="2" Width="84" Style="{StaticResource CompactComboBoxStyle}" SelectionChanged="TargetSlotComboBox_SelectionChanged"/>

                    <TextBlock Grid.Row="6" Text="Color:" Style="{StaticResource SectionLabelStyle}"/>
                    <TextBox x:Name="SelectedColorTextBox" Grid.Row="6" Grid.Column="2" Width="110" Style="{StaticResource CompactTextBoxStyle}"/>
                    <Button x:Name="PickSelectedColorButton" Grid.Row="6" Grid.Column="4" Width="50" Style="{StaticResource SmallButtonStyle}" Content="pick" Click="PickSelectedColorButton_Click"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LblMain"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ValA"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="transform anims:" Style="{StaticResource SectionLabelStyle}"/>
                    <ComboBox x:Name="TransformAnimationComboBox" Grid.Column="2" Width="180" Style="{StaticResource CompactComboBoxStyle}"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ApplyButton" Style="{StaticResource SmallButtonStyle}" Width="70" Margin="0,0,8,0" Content="Apply" Click="ApplyButton_Click"/>
                <Button x:Name="CloseButton" Style="{StaticResource SmallButtonStyle}" Width="70" Content="Close" Click="CloseButton_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
