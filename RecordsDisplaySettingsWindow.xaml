<Window x:Class="TmnfDedimaniaScraper.RecordsDisplaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Show Records Settings"
        Width="460"
        Height="540"
        MinWidth="420"
        MinHeight="420"
        WindowStartupLocation="Manual"
        Background="#0F172A"
        Foreground="#E5E7EB"
        Icon="pack://application:,,,/Assets/f1_app_icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#253244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
        </Style>

        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="74"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SectionTabButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Display settings" FontSize="18" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="TextSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Text" Click="TextSectionButton_Click"/>
            <Button x:Name="LayoutSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Layout" Click="LayoutSectionButton_Click"/>
            <Button x:Name="BackgroundSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Background" Click="BackgroundSectionButton_Click"/>
            <Button x:Name="ColorSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Color" Click="ColorSectionButton_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Border x:Name="TextSectionBorder" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Record count" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="ShowCountTextBox" Grid.Row="0" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" TextChanged="ShowCountTextBox_TextChanged" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="2" Text="Title size" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="TitleSizeTextBox" Grid.Row="2" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="4" Text="Text size" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="FontSizeTextBox" Grid.Row="4" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="6" Text="Text weight" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="FontWeightComboBox" Grid.Row="6" Grid.Column="1" Width="120" Style="{StaticResource CompactComboBoxStyle}" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Normal"/>
                            <ComboBoxItem Content="Bold"/>
                        </ComboBox>

                        <TextBlock Grid.Row="8" Text="Transform anims" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="TransformAnimationComboBox" Grid.Row="8" Grid.Column="1" Width="140" Style="{StaticResource CompactComboBoxStyle}" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <Border x:Name="LayoutSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Text="Position:" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="X" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Y" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                            <TextBox x:Name="WindowLeftTextBox" Grid.Row="2" Grid.Column="1" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                            <TextBox x:Name="WindowTopTextBox" Grid.Row="2" Grid.Column="3" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Text="Size:" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="W" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="H" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                            <TextBox x:Name="WindowWidthTextBox" Grid.Row="2" Grid.Column="1" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                            <TextBox x:Name="WindowHeightTextBox" Grid.Row="2" Grid.Column="3" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="84"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="88"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Text="Spacing:" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Vertical" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Rank-&gt;Time" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Row="0" Grid.Column="5" Text="Time-&gt;By" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                            <TextBox x:Name="VerticalSpacingTextBox" Grid.Row="2" Grid.Column="1" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                            <TextBox x:Name="RankTimeSpacingTextBox" Grid.Row="2" Grid.Column="3" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                            <TextBox x:Name="TimeBySpacingTextBox" Grid.Row="2" Grid.Column="5" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="BackgroundSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Background color" Style="{StaticResource FieldLabelStyle}"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="BackgroundColorTextBox" Width="160" Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,8,0"/>
                            <Button x:Name="PickBackgroundColorButton" Width="56" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickBackgroundColorButton_Click"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Text="Background opacity" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="BackgroundOpacityTextBox" Grid.Row="2" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="4" Text="Border radius" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="BorderRadiusTextBox" Grid.Row="4" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                    </Grid>
                </Border>

                <Border x:Name="ColorSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Table" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="Table1TabButton" Style="{StaticResource ToggleButtonStyle}" Content="Table 1" Click="Table1TabButton_Click"/>
                                <Button x:Name="Table2TabButton" Style="{StaticResource ToggleButtonStyle}" Margin="0" Content="Table 2" Click="Table2TabButton_Click"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="RankItemTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Rank" Click="RankItemTabButton_Click"/>
                                <Button x:Name="TimeItemTabButton" Style="{StaticResource ToggleButtonStyle}" Margin="0" Content="Time" Click="TimeItemTabButton_Click"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Record slot" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="TargetSlotComboBox" Grid.Column="1" Width="120" Style="{StaticResource CompactComboBoxStyle}" HorizontalAlignment="Left" SelectionChanged="TargetSlotComboBox_SelectionChanged"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox x:Name="SelectedColorTextBox" Width="160" Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,8,0" TextChanged="SelectedColorTextBox_TextChanged"/>
                                <Button x:Name="PickSelectedColorButton" Width="56" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickSelectedColorButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ApplyButton" Style="{StaticResource PrimaryButtonStyle}" Width="78" Margin="0,0,8,0" Content="Apply" Click="ApplyButton_Click"/>
            <Button x:Name="CloseButton" Style="{StaticResource PrimaryButtonStyle}" Width="78" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
