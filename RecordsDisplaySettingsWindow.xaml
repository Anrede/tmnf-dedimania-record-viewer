<Window x:Class="TmnfDedimaniaScraper.RecordsDisplaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Show Records Settings"
        Width="490"
        Height="560"
        MinWidth="490"
        MinHeight="560"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True"
        Background="#0F172A"
        Foreground="#E5E7EB"
        Icon="pack://application:,,,/Assets/f1_app_icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#253244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
        </Style>

        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="MaxLength" Value="4"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="RangeComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource CompactComboBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="64"/>
        </Style>

        <Style x:Key="SmallSettingComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource CompactComboBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="92"/>
        </Style>

        
        <Style x:Key="BackgroundSelectorTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="136"/>
            <Setter Property="MaxLength" Value="512"/>
        </Style>
        
        <Style x:Key="RGBTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="112"/>
            <Setter Property="MaxLength" Value="18"/>
        </Style>

        <Style x:Key="BackgroundSelectorComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource CompactComboBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="136"/>
        </Style>

        <Style x:Key="TextAlignmentComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource CompactComboBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="84"/>
        </Style>

        <Style x:Key="PaddingSideTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="MaxLength" Value="4"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="TextsTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="92"/>
            <Setter Property="MaxLength" Value="256"/>
        </Style>

        <Style x:Key="InfoBadgeHostStyle" TargetType="Grid">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Margin" Value="6,0,0,2"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="500"/>
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
            <Setter Property="ToolTipService.ShowDuration" Value="25000"/>
        </Style>

        <Style x:Key="InfoBadgeBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BorderBrush" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="12">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="64"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SectionTabButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Display settings" FontSize="18" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="TextSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Text" Click="TextSectionButton_Click"/>
            <Button x:Name="LayoutSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Layout" Click="LayoutSectionButton_Click"/>
            <Button x:Name="PaddingSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Padding" Click="PaddingSectionButton_Click"/>
            <Button x:Name="BackgroundSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Background" Click="BackgroundSectionButton_Click"/>
            <Button x:Name="ColorSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Color" Click="ColorSectionButton_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Border x:Name="TextSectionBorder" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Text Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Title" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Text" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Map" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Size" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TitleSizeTextBox" Grid.Row="2" Grid.Column="2" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="FontSizeTextBox" Grid.Row="2" Grid.Column="4" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="MapSizeTextBox" Grid.Row="2" Grid.Column="6" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Record count" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="ShowCountTextBox" Grid.Column="2" Style="{StaticResource PaddingSideTextBoxStyle}" TextChanged="ShowCountTextBox_TextChanged" HorizontalAlignment="Left" MaxLength="2"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Text weight" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="FontWeightComboBox" Grid.Column="2" Style="{StaticResource SmallSettingComboBoxStyle}" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Normal"/>
                                        <ComboBoxItem Content="Bold"/>
                                    </ComboBox>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Transform anims" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <ComboBox x:Name="TransformAnimationComboBox" Grid.Column="2" Style="{StaticResource SmallSettingComboBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Texts" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="84"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Title" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TitleTextContentTextBox" Grid.Column="2" Style="{StaticResource TextsTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <ComboBox x:Name="TitleAlignmentComboBox" Grid.Column="4" Style="{StaticResource TextAlignmentComboBoxStyle}" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Alignment"/>
                                        <ComboBoxItem Content="Left"/>
                                        <ComboBoxItem Content="Center"/>
                                        <ComboBoxItem Content="Right"/>
                                    </ComboBox>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="84"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Map" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="MapLabelTextContentTextBox" Grid.Column="2" Style="{StaticResource TextsTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <ComboBox x:Name="MapAlignmentComboBox" Grid.Column="4" Style="{StaticResource TextAlignmentComboBoxStyle}" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Alignment"/>
                                        <ComboBoxItem Content="Left"/>
                                        <ComboBoxItem Content="Center"/>
                                        <ComboBoxItem Content="Right"/>
                                    </ComboBox>
                                    <CheckBox x:Name="ShowMapNameCheckBox" Grid.Column="6" VerticalAlignment="Center" HorizontalAlignment="Left" IsChecked="True"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="LayoutSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Position" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" VerticalAlignment="Bottom"/>
                                    <Grid Style="{StaticResource InfoBadgeHostStyle}">
                                        <Grid.ToolTip>
                                            <ToolTip Style="{StaticResource InfoToolTipStyle}">
                                                <TextBlock Width="340" TextWrapping="Wrap" Foreground="#E5E7EB"
                                                           Text="The top-left corner of the Records window container starts at the monitor's top-left corner, where X=0 and Y=0.&#x0a;Positive X values move the window container to the right.&#x0a;Positive Y values move the window container downward."/>
                                            </ToolTip>
                                        </Grid.ToolTip>
                                        <Border Style="{StaticResource InfoBadgeBorderStyle}">
                                            <TextBlock Text="?" Foreground="#E2E8F0" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="X" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Y" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Axis" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="WindowLeftTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="WindowTopTextBox" Grid.Row="2" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Size" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" VerticalAlignment="Bottom"/>
                                    <Grid Style="{StaticResource InfoBadgeHostStyle}">
                                        <Grid.ToolTip>
                                            <ToolTip Style="{StaticResource InfoToolTipStyle}">
                                                <TextBlock Width="340" TextWrapping="Wrap" Foreground="#E5E7EB"
                                                           Text="Positive Width values make the Records window container grow to the right.&#x0a;Positive Height values make the Records window container grow downward."/>
                                            </ToolTip>
                                        </Grid.ToolTip>
                                        <Border Style="{StaticResource InfoBadgeBorderStyle}">
                                            <TextBlock Text="?" Foreground="#E2E8F0" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Width" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Height" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Adjust" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="WindowWidthTextBox" Grid.Row="2" Grid.Column="1" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="WindowHeightTextBox" Grid.Row="2" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="PaddingSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Padding Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" VerticalAlignment="Bottom"/>
                                    <Grid Style="{StaticResource InfoBadgeHostStyle}">
                                        <Grid.ToolTip>
                                            <ToolTip Style="{StaticResource InfoToolTipStyle}">
                                                <TextBlock Width="340" TextWrapping="Wrap" Foreground="#E5E7EB"
                                                           Text="These paddings work as Left, Right, Top, and Bottom values.&#x0a;When the checkbox is checked, editing one box applies the same value to all four sides.&#x0a;Frame padding still accepts negative values so the frame can grow beyond the container."/>
                                            </ToolTip>
                                        </Grid.ToolTip>
                                        <Border Style="{StaticResource InfoBadgeBorderStyle}">
                                            <TextBlock Text="?" Foreground="#E2E8F0" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="3" Text="Left" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="Right" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="7" Text="Top" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="9" Text="Bottom" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Text padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="TextPaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="TextPaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="TextPaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="TextPaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="TextPaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Color padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="BackgroundColorPaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="BackgroundColorPaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="BackgroundColorPaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="BackgroundColorPaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="BackgroundColorPaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Frame padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="FramePaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="FramePaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="FramePaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="FramePaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="FramePaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Image padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="ImagePaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="ImagePaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="ImagePaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="ImagePaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="ImagePaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Text Spacings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" VerticalAlignment="Bottom"/>
                                    <Grid Style="{StaticResource InfoBadgeHostStyle}">
                                        <Grid.ToolTip>
                                            <ToolTip Style="{StaticResource InfoToolTipStyle}">
                                                <TextBlock Width="340" TextWrapping="Wrap" Foreground="#E5E7EB"
                                                           Text="Controls the vertical and horizontal spacing between the text elements."/>
                                            </ToolTip>
                                        </Grid.ToolTip>
                                        <Border Style="{StaticResource InfoBadgeBorderStyle}">
                                            <TextBlock Text="?" Foreground="#E2E8F0" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="2" Text="Title-&gt;" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="Text-&gt;" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="6" Text="Map-&gt;" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Vertical spacing" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="TitleTextSpacingTextBox" Grid.Column="2" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="VerticalSpacingTextBox" Grid.Column="4" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="TextMapSpacingTextBox" Grid.Column="6" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="2" Text="Rank-&gt;" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="Time-&gt;" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Horizontal spacing" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <TextBox x:Name="RankTimeSpacingTextBox" Grid.Column="2" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="TimeBySpacingTextBox" Grid.Column="4" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="BackgroundSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Color" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Preset color" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="BackgroundColorPresetComboBox" Grid.Column="1" Style="{StaticResource BackgroundSelectorComboBoxStyle}" HorizontalAlignment="Left" SelectionChanged="BackgroundColorPresetComboBox_Activated" GotFocus="BackgroundColorPresetComboBox_Activated" DropDownOpened="BackgroundColorPresetComboBox_Activated"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Custom color" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="BackgroundColorTextBox" Width="136" Style="{StaticResource RGBTextBoxStyle}" Margin="0,0,8,0" GotFocus="BackgroundColorTextBox_Activated"/>
                                        <Button x:Name="PickBackgroundColorButton" Width="72" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickBackgroundColorButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Color opacity" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BackgroundOpacityTextBox" Grid.Column="1" Width="42" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Border radius" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BorderRadiusTextBox" Grid.Column="1" Width="42" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Image" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Preset image" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="BuiltInBackgroundComboBox" Grid.Column="1" Style="{StaticResource BackgroundSelectorComboBoxStyle}" HorizontalAlignment="Left" SelectionChanged="BuiltInBackgroundComboBox_Activated" GotFocus="BuiltInBackgroundComboBox_Activated" DropDownOpened="BuiltInBackgroundComboBox_Activated"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Custom image" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="CustomBackgroundPathTextBox" Style="{StaticResource BackgroundSelectorTextBoxStyle}" Margin="0,0,8,0" GotFocus="CustomBackgroundPathTextBox_Activated"/>
                                        <Button x:Name="BrowseBackgroundButton" Width="72" Style="{StaticResource PrimaryButtonStyle}" Content="Browse" Click="BrowseBackgroundButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Image opacity" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BackgroundImageOpacityTextBox" Grid.Column="1" Width="42" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Border radius" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BackgroundImageBorderRadiusTextBox" Grid.Column="1" Width="42" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Frame" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Preset frame" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="BuiltInFrameComboBox" Grid.Column="1" Style="{StaticResource BackgroundSelectorComboBoxStyle}" HorizontalAlignment="Left" SelectionChanged="BuiltInFrameComboBox_Activated" GotFocus="BuiltInFrameComboBox_Activated" DropDownOpened="BuiltInFrameComboBox_Activated"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Custom frame" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="CustomFramePathTextBox" Style="{StaticResource BackgroundSelectorTextBoxStyle}" Margin="0,0,8,0" GotFocus="CustomFramePathTextBox_Activated"/>
                                        <Button x:Name="BrowseFrameButton" Width="72" Style="{StaticResource PrimaryButtonStyle}" Content="Browse" Click="BrowseFrameButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame opacity" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="FrameOpacityTextBox" Grid.Column="1" Width="42" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame radius" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="FrameRadiusTextBox" Grid.Column="1" Width="42" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="ColorSectionBorder" Style="{StaticResource CardStyle}" Visibility="Visible">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Rank &amp; Time Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Table" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="Table1TabButton" Grid.Column="1" Style="{StaticResource ToggleButtonStyle}" Content="Table 1" Click="Table1TabButton_Click"/>
                                        <Button x:Name="Table2TabButton" Grid.Column="3" Style="{StaticResource ToggleButtonStyle}" Content="Table 2" Click="Table2TabButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Item" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="RankItemTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Rank" Click="RankItemTabButton_Click"/>
                                        <Button x:Name="TimeItemTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Time" Click="TimeItemTabButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Record slot" Style="{StaticResource FieldLabelStyle}"/>
                                    <Grid Grid.Column="1" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="64"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="StartSlotComboBox" Grid.Column="0" Style="{StaticResource RangeComboBoxStyle}" SelectionChanged="StartSlotComboBox_SelectionChanged"/>
                                        <ComboBox x:Name="EndSlotComboBox" Grid.Column="2" Style="{StaticResource RangeComboBoxStyle}" SelectionChanged="EndSlotComboBox_SelectionChanged"/>
                                    </Grid>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="SelectedColorTextBox" Width="136" Style="{StaticResource RGBTextBoxStyle}" Margin="0,0,8,0" TextChanged="SelectedColorTextBox_TextChanged"/>
                                        <Button x:Name="PickSelectedColorButton" Width="50" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickSelectedColorButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Other Text Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Text" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="TitleColorTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Title" Click="TitleColorTabButton_Click"/>
                                        <Button x:Name="MapLabelColorTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Map:" Click="MapLabelColorTabButton_Click"/>
                                        <Button x:Name="MapNameColorTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Name" Click="MapNameColorTabButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="DisplayElementColorTextBox" Width="136" Style="{StaticResource RGBTextBoxStyle}" Margin="0,0,8,0" TextChanged="DisplayElementColorTextBox_TextChanged"/>
                                        <Button x:Name="PickDisplayElementColorButton" Width="56" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickDisplayElementColorButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ApplyButton" Style="{StaticResource PrimaryButtonStyle}" Width="78" Margin="0,0,8,0" Content="Apply" Click="ApplyButton_Click"/>
            <Button x:Name="CloseButton" Style="{StaticResource PrimaryButtonStyle}" Width="78" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
