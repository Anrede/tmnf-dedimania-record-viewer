<Window x:Class="TmnfDedimaniaScraper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:TmnfDedimaniaScraper"
        mc:Ignorable="d"
        Title="TMNF Record Controls" Icon="pack://application:,,,/Assets/f1_app_icon.ico"
        Width="1680"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        Background="#111827"
        Foreground="#E5E7EB">

    <Window.Resources>
        <local:CssColorToBrushConverter x:Key="CssColorToBrushConverter" />
        <local:CssFontWeightConverter x:Key="CssFontWeightConverter" />
        <local:CssFontStyleConverter x:Key="CssFontStyleConverter" />
        <local:CssFontSizeConverter x:Key="CssFontSizeConverter" />
        <local:CssFontFamilyConverter x:Key="CssFontFamilyConverter" />

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="PanelAltBackgroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#374151" />
        <SolidColorBrush x:Key="ForegroundBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="SubtleForegroundBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#38BDF8" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="RowHoverBrush" Color="#253246" />
        <SolidColorBrush x:Key="RowSelectedBrush" Color="#0C4A6E" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#2563EB" />
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8" />
                    <Setter Property="BorderBrush" Value="#1D4ED8" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="BorderBrush" Value="#991B1B"/>
        </Style>

        <Style x:Key="ChromeNavButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="BookmarkChipStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MaxWidth" Value="260"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="LayoutGridSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="ShowsPreview" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#334155" BorderThickness="1" CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelAltBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#253041" />
            <Setter Property="VerticalGridLinesBrush" Value="#253041" />
            <Setter Property="RowBackground" Value="{StaticResource PanelAltBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground" Value="#132033" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="CanUserReorderColumns" Value="True" />
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="#253041" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource PanelAltBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowSelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Background="#0B1220"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" x:Name="BackButton" Style="{StaticResource ChromeNavButtonStyle}" Margin="0,0,8,0" Click="BackButton_Click" ToolTip="Back" Content="←"/>
                    <Button Grid.Column="1" x:Name="ForwardButton" Style="{StaticResource ChromeNavButtonStyle}" Margin="0,0,8,0" Click="ForwardButton_Click" ToolTip="Forward" Content="→"/>
                    <Button Grid.Column="2" x:Name="ReloadButton" Style="{StaticResource ChromeNavButtonStyle}" Margin="0,0,10,0" Click="ReloadButton_Click" ToolTip="Reload" Content="↻"/>

                    <TextBox x:Name="UrlTextBox" Grid.Column="3" Margin="0,0,10,0" Padding="12,8" FontSize="14" KeyDown="UrlTextBox_KeyDown" Text="https://tmnf.exchange/trackshow/9684537"/>
                    <Button Grid.Column="4" x:Name="LoadButton" Width="110" Height="38" Margin="0,0,8,0" Click="LoadButton_Click" Content="Open Site"/>
                    <Button Grid.Column="5" x:Name="ScrapeButton" Width="120" Height="38" Margin="0,0,8,0" Click="ScrapeButton_Click" Content="Fetch Data"/>
                    <Button Grid.Column="6" x:Name="AddBookmarkButton" Width="90" Height="38" Margin="0,0,8,0" Click="AddBookmarkButton_Click" Content="☆ Save"/>
                    <Button Grid.Column="7" x:Name="RemoveBookmarkButton" Width="74" Height="38" Click="RemoveBookmarkButton_Click" Content="✕ Remove"/>
                </Grid>

                <Border Grid.Row="1" Margin="0,10,0,0" Background="#111827" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10,8">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left" Margin="0,0,12,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#93C5FD" Text="Bookmarks"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" CanContentScroll="True">
                            <ItemsControl x:Name="BookmarksItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource BookmarkChipStyle}" Click="BookmarkButton_Click" ToolTip="{Binding Url}">
                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftMainColumn" Width="1.3*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition x:Name="RightMainColumn" Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="LeftBrowserRow" Height="2.7*"/>
                <RowDefinition Height="8"/>
                <RowDefinition x:Name="LeftSegmentsRow" Height="2.2*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0"
                    Margin="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <wv2:WebView2 x:Name="Browser" Margin="1"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="1" Grid.Column="0"
                          Height="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          DragCompleted="LayoutSplitter_DragCompleted"
                          Style="{StaticResource LayoutGridSplitterStyle}"/>

            <Border Grid.Row="2" Grid.Column="0"
                    Margin="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Segment details" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>

                        <Grid Grid.Column="2" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="86"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="74"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="88"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Style" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" x:Name="SegmentStyleMenuButton" Height="28" Width="86" Padding="10,4" Click="SegmentStyleMenuButton_Click" Content="normal ▾">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="normal" Click="SegmentStyleMenuItem_Click"/>
                                        <MenuItem Header="italic" Click="SegmentStyleMenuItem_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <TextBlock Grid.Column="3" Text="Color" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Border Grid.Column="4" x:Name="SelectedColorPreviewBorder" Height="28" Cursor="Hand" CornerRadius="6" BorderBrush="#475569" BorderThickness="1" Background="Transparent" ToolTip="Click to open the color picker" MouseLeftButtonUp="SelectedColorPreviewBorder_MouseLeftButtonUp"/>

                            <TextBlock Grid.Column="6" Text="R" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="7" x:Name="RedTextBox" Height="28"/>
                            <TextBlock Grid.Column="9" Text="G" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="10" x:Name="GreenTextBox" Height="28"/>
                            <TextBlock Grid.Column="12" Text="B" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="13" x:Name="BlueTextBox" Height="28"/>
                            <Button Grid.Column="15" x:Name="ApplyRgbButton" Width="88" Height="28" Click="ApplyRgbButton_Click" Content="Apply RGB"/>
                        </Grid>
                    </Grid>

                    <DataGrid Grid.Row="1" x:Name="SegmentsGrid" HeadersVisibility="Column" RowHeaderWidth="0" RowDetailsVisibilityMode="Collapsed" AutoGenerateColumns="False" CanUserSortColumns="False" SelectionChanged="SegmentsGrid_SelectionChanged" BeginningEdit="SegmentsGrid_BeginningEdit">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Field" Binding="{Binding CellName}" Width="72" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Swatch" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="20" CornerRadius="5" BorderBrush="#64748B" BorderThickness="1" Background="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="BgColor" Binding="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Text" Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                            <DataGridTextColumn Header="Weight" Binding="{Binding FontWeight, UpdateSourceTrigger=PropertyChanged}" Width="72"/>
                            <DataGridTemplateColumn Header="Style" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FontStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValuePath="Content" SelectedValue="{Binding FontStyle, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Content="normal"/>
                                            <ComboBoxItem Content="italic"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Decoration" Binding="{Binding TextDecoration, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                            <DataGridTextColumn Header="FontSize" Binding="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" Width="82"/>
                            <DataGridTextColumn Header="FontFamily" Binding="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Class" Binding="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Tag" Binding="{Binding Tag, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          DragCompleted="LayoutSplitter_DragCompleted"
                          Style="{StaticResource LayoutGridSplitterStyle}"/>

            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="RightRecordsRow" Height="2.2*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition x:Name="RightTablesRow" Height="1.2*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition x:Name="RightPreviewRow" Height="170"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button x:Name="OnlineTabButton" Style="{StaticResource SecondaryButtonStyle}" Width="76" Height="28" Padding="0" Margin="0,0,6,0" Click="OnlineTabButton_Click" Content="Online"/>
                                    <Button x:Name="OfflineTabButton" Style="{StaticResource SecondaryButtonStyle}" Width="76" Height="28" Padding="0" Margin="0,0,6,0" Click="OfflineTabButton_Click" Content="Offline"/>
                                    <Button x:Name="MergeOfflineButton" Style="{StaticResource SecondaryButtonStyle}" Width="88" Height="28" Padding="0" Click="MergeOfflineButton_Click" Content="Merge" IsEnabled="False"/>
                                </StackPanel>
                                <Button x:Name="RecordsMenuButton" DockPanel.Dock="Left" Style="{StaticResource SecondaryButtonStyle}" Width="30" Height="26" Padding="0" Margin="0,0,8,0" Click="RecordsMenuButton_Click" Content="▾">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Export (.txt)" Click="ExportRecordsMenuItem_Click"/>
                                            <MenuItem Header="Import (.txt)" Click="ImportRecordsMenuItem_Click"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                                <TextBlock DockPanel.Dock="Left" Text="Fetched records" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TrackNameHeaderText" DockPanel.Dock="Left" Text="  •  -" Margin="8,0,0,0" Foreground="{StaticResource SubtleForegroundBrush}" VerticalAlignment="Center"/>
                            </DockPanel>

                            <Grid Grid.Row="1">
                                <DataGrid x:Name="RecordsGrid" HeadersVisibility="Column" RowHeaderWidth="0" RowDetailsVisibilityMode="Collapsed" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="RecordsGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="90"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="130"/>
                                        <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="90"/>
                                        <DataGridTextColumn Header="By" Binding="{Binding By}" Width="260"/>
                                        <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="260"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <DataGrid x:Name="OfflineRecordsGrid" HeadersVisibility="Column" RowHeaderWidth="0" RowDetailsVisibilityMode="Collapsed" AutoGenerateColumns="False" IsReadOnly="True" Visibility="Collapsed" SelectionChanged="OfflineRecordsGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="90"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="130"/>
                                        <DataGridTextColumn Header="By" Binding="{Binding By}" Width="260"/>
                                        <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="140"/>
                                        <DataGridTextColumn Header="LB" Binding="{Binding LB}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  DragCompleted="LayoutSplitter_DragCompleted"
                                  Style="{StaticResource LayoutGridSplitterStyle}"/>

                    <Border Grid.Row="2" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Custom tables" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="ShowRecordsSettingsButton" Style="{StaticResource SecondaryButtonStyle}" Width="92" Height="30" Margin="0,0,12,0" Click="ShowRecordsSettingsButton_Click" Content="Settings"/>
                                    <Button x:Name="ShowRecordsButton" Style="{StaticResource SecondaryButtonStyle}" Width="110" Height="30" Click="ShowRecordsButton_Click" Content="Show Records"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button x:Name="Table1MenuButton" Style="{StaticResource SecondaryButtonStyle}" Width="30" Height="26" Padding="0" Margin="0,0,8,0" Click="Table1MenuButton_Click" Content="▾">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Export (.txt)" Click="ExportTable1MenuItem_Click"/>
                                                        <MenuItem Header="Import (.txt)" Click="ImportTable1MenuItem_Click"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                            <TextBlock Text="Table 1" FontWeight="SemiBold" Foreground="#93C5FD" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid Grid.Row="1" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="Table1RankInput" Margin="0,0,8,0" ToolTip="Enter the insert position: 1, 2, 3..."/>
                                            <Button Grid.Column="1" Width="72" Margin="0,0,8,0" Click="AddTable1ItemButton_Click" Content="Add"/>
                                            <Button Grid.Column="2" Width="100" Style="{StaticResource DangerButtonStyle}" Click="RemoveTable1ItemButton_Click" Content="Remove Selected"/>
                                        </Grid>

                                        <DataGrid Grid.Row="2" x:Name="Table1Grid" HeadersVisibility="Column" RowHeaderWidth="0" RowDetailsVisibilityMode="Collapsed" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="Table1Grid_SelectionChanged">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="90"/>
                                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="130"/>
                                                <DataGridTextColumn Header="By" Binding="{Binding By}" Width="220"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button x:Name="Table2MenuButton" Style="{StaticResource SecondaryButtonStyle}" Width="30" Height="26" Padding="0" Margin="0,0,8,0" Click="Table2MenuButton_Click" Content="▾">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Export (.txt)" Click="ExportTable2MenuItem_Click"/>
                                                        <MenuItem Header="Import (.txt)" Click="ImportTable2MenuItem_Click"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                            <TextBlock Text="Table 2" FontWeight="SemiBold" Foreground="#93C5FD" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Grid Grid.Row="1" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="Table2RankInput" Margin="0,0,8,0" ToolTip="Enter the insert position: 1, 2, 3..."/>
                                            <Button Grid.Column="1" Width="72" Margin="0,0,8,0" Click="AddTable2ItemButton_Click" Content="Add"/>
                                            <Button Grid.Column="2" Width="100" Style="{StaticResource DangerButtonStyle}" Click="RemoveTable2ItemButton_Click" Content="Remove Selected"/>
                                        </Grid>

                                        <DataGrid Grid.Row="2" x:Name="Table2Grid" HeadersVisibility="Column" RowHeaderWidth="0" RowDetailsVisibilityMode="Collapsed" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="Table2Grid_SelectionChanged">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="90"/>
                                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="130"/>
                                                <DataGridTextColumn Header="By" Binding="{Binding By}" Width="220"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="3"
                                  Height="8"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  DragCompleted="LayoutSplitter_DragCompleted"
                                  Style="{StaticResource LayoutGridSplitterStyle}"/>

                    <Border Grid.Row="4" Margin="0" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Preview" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <DataGrid Grid.Row="1" x:Name="PreviewGrid" HeadersVisibility="Column" RowHeaderWidth="0" RowDetailsVisibilityMode="Collapsed" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="False" SelectionMode="Single" SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn x:Name="PreviewRankColumn" Header="#" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding RankSegments}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}"
                                                                       FontWeight="{Binding FontWeight, Converter={StaticResource CssFontWeightConverter}}"
                                                                       FontStyle="{Binding FontStyle, Converter={StaticResource CssFontStyleConverter}}"
                                                                       FontFamily="{Binding FontFamily, Converter={StaticResource CssFontFamilyConverter}}"
                                                                       FontSize="{Binding FontSize, Converter={StaticResource CssFontSizeConverter}}"
                                                                       VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="PreviewTimeColumn" Header="Time" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding TimeSegments}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}" FontWeight="{Binding FontWeight, Converter={StaticResource CssFontWeightConverter}}" FontStyle="{Binding FontStyle, Converter={StaticResource CssFontStyleConverter}}" FontFamily="{Binding FontFamily, Converter={StaticResource CssFontFamilyConverter}}" FontSize="{Binding FontSize, Converter={StaticResource CssFontSizeConverter}}" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="PreviewModeColumn" Header="Mode" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding ModeSegments}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}" FontWeight="{Binding FontWeight, Converter={StaticResource CssFontWeightConverter}}" FontStyle="{Binding FontStyle, Converter={StaticResource CssFontStyleConverter}}" FontFamily="{Binding FontFamily, Converter={StaticResource CssFontFamilyConverter}}" FontSize="{Binding FontSize, Converter={StaticResource CssFontSizeConverter}}" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="PreviewByColumn" Header="By" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding BySegments}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}" FontWeight="{Binding FontWeight, Converter={StaticResource CssFontWeightConverter}}" FontStyle="{Binding FontStyle, Converter={StaticResource CssFontStyleConverter}}" FontFamily="{Binding FontFamily, Converter={StaticResource CssFontFamilyConverter}}" FontSize="{Binding FontSize, Converter={StaticResource CssFontSizeConverter}}" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="PreviewServerColumn" Header="Server" Width="240">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding ServerSegments}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}" FontWeight="{Binding FontWeight, Converter={StaticResource CssFontWeightConverter}}" FontStyle="{Binding FontStyle, Converter={StaticResource CssFontStyleConverter}}" FontFamily="{Binding FontFamily, Converter={StaticResource CssFontFamilyConverter}}" FontSize="{Binding FontSize, Converter={StaticResource CssFontSizeConverter}}" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="PreviewScoreColumn" Header="Score" Width="140" Visibility="Collapsed">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding ScoreSegments}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}" FontWeight="{Binding FontWeight, Converter={StaticResource CssFontWeightConverter}}" FontStyle="{Binding FontStyle, Converter={StaticResource CssFontStyleConverter}}" FontFamily="{Binding FontFamily, Converter={StaticResource CssFontFamilyConverter}}" FontSize="{Binding FontSize, Converter={StaticResource CssFontSizeConverter}}" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn x:Name="PreviewLBColumn" Header="LB" Width="90" Visibility="Collapsed">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding LBSegments}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}" FontWeight="{Binding FontWeight, Converter={StaticResource CssFontWeightConverter}}" FontStyle="{Binding FontStyle, Converter={StaticResource CssFontStyleConverter}}" FontFamily="{Binding FontFamily, Converter={StaticResource CssFontFamilyConverter}}" FontSize="{Binding FontSize, Converter={StaticResource CssFontSizeConverter}}" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <StatusBar Grid.Row="2" Background="#0B1220" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Margin="0,12,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
