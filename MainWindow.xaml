<Window x:Class="TmnfDedimaniaScraper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:TmnfDedimaniaScraper"
        mc:Ignorable="d"
        Title="TMNF Dedimania Online Records Scraper"
        Width="1680"
        Height="1080"
        WindowStartupLocation="CenterScreen"
        Background="#111827"
        Foreground="#E5E7EB">

    <Window.Resources>
        <local:CssColorToBrushConverter x:Key="CssColorToBrushConverter" />

        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="PanelAltBackgroundBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#374151" />
        <SolidColorBrush x:Key="ForegroundBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="SubtleForegroundBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#38BDF8" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="RowHoverBrush" Color="#253246" />
        <SolidColorBrush x:Key="RowSelectedBrush" Color="#0C4A6E" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#2563EB" />
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D4ED8" />
                    <Setter Property="BorderBrush" Value="#1D4ED8" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="BorderBrush" Value="#991B1B"/>
        </Style>

        <Style x:Key="ChromeNavButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="BookmarkChipStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MaxWidth" Value="260"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelAltBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#253041" />
            <Setter Property="VerticalGridLinesBrush" Value="#253041" />
            <Setter Property="RowBackground" Value="{StaticResource PanelAltBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground" Value="#132033" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="BorderBrush" Value="#253041" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource PanelAltBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowSelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2.35*"/>
            <RowDefinition Height="1.55*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Background="#0B1220"
                BorderBrush="{StaticResource BorderBrushDark}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="BackButton"
                            Style="{StaticResource ChromeNavButtonStyle}"
                            Margin="0,0,8,0"
                            Click="BackButton_Click"
                            ToolTip="Önceki sayfa"
                            Content="←"/>

                    <Button Grid.Column="1"
                            x:Name="ForwardButton"
                            Style="{StaticResource ChromeNavButtonStyle}"
                            Margin="0,0,8,0"
                            Click="ForwardButton_Click"
                            ToolTip="Sonraki sayfa"
                            Content="→"/>

                    <Button Grid.Column="2"
                            x:Name="ReloadButton"
                            Style="{StaticResource ChromeNavButtonStyle}"
                            Margin="0,0,10,0"
                            Click="ReloadButton_Click"
                            ToolTip="Yenile"
                            Content="↻"/>

                    <TextBox x:Name="UrlTextBox"
                             Grid.Column="3"
                             Margin="0,0,10,0"
                             Padding="12,8"
                             FontSize="14"
                             KeyDown="UrlTextBox_KeyDown"
                             Text="https://tmnf.exchange/trackshow/9684537"/>

                    <Button Grid.Column="4"
                            x:Name="LoadButton"
                            Width="110"
                            Height="38"
                            Margin="0,0,8,0"
                            Click="LoadButton_Click"
                            Content="Siteyi Aç"/>

                    <Button Grid.Column="5"
                            x:Name="ScrapeButton"
                            Width="120"
                            Height="38"
                            Margin="0,0,8,0"
                            Click="ScrapeButton_Click"
                            Content="Veriyi Çek"/>

                    <Button Grid.Column="6"
                            x:Name="AddBookmarkButton"
                            Width="90"
                            Height="38"
                            Margin="0,0,8,0"
                            Click="AddBookmarkButton_Click"
                            Content="☆ Kaydet"/>

                    <Button Grid.Column="7"
                            x:Name="RemoveBookmarkButton"
                            Width="74"
                            Height="38"
                            Click="RemoveBookmarkButton_Click"
                            Content="✕ Sil"/>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,10,0,0"
                        Background="#111827"
                        BorderBrush="#243244"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10,8">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#93C5FD"
                                   Text="Yer İmleri"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      CanContentScroll="True">
                            <ItemsControl x:Name="BookmarksItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource BookmarkChipStyle}"
                                                Click="BookmarkButton_Click"
                                                ToolTip="{Binding Url}">
                                            <TextBlock Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.34*"/>
                    <RowDefinition Height="0.82*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,10">
                    <Grid>
                        <wv2:WebView2 x:Name="Browser" Margin="1"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Dedimania görünüm önizleme" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <Border Grid.Row="1" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="#" Foreground="#93C5FD" Margin="0,0,10,8" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Time" Foreground="#93C5FD" Margin="0,0,10,8" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Mode" Foreground="#93C5FD" Margin="0,0,10,8" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="By" Foreground="#93C5FD" Margin="0,0,10,8" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Server" Foreground="#93C5FD" Margin="0,0,0,8" FontWeight="SemiBold"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="PreviewRankText" FontSize="16" FontWeight="Bold" Text="-" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PreviewTimeText" FontSize="16" FontWeight="SemiBold" Text="-" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" x:Name="PreviewModeText" FontSize="16" Text="-" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="PreviewByText" FontSize="16" Text="-" TextWrapping="Wrap" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="4" x:Name="PreviewServerText" FontSize="16" Text="-" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1.1*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Çekilen kayıtlar" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="  •  Veriyi çek dediğinde eski sonuçlar temizlenir" Margin="8,0,0,0" Foreground="{StaticResource SubtleForegroundBrush}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="RecordsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="RecordsGrid_SelectionChanged"
                              MinWidth="880">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="90"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="130"/>
                            <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="90"/>
                            <DataGridTextColumn Header="By" Binding="{Binding By}" Width="260"/>
                            <DataGridTextColumn Header="Server" Binding="{Binding Server}" Width="260"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Text="Yeni tablolar (Rank / Time / By)" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,8"/>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Tablo 1" FontWeight="SemiBold" Foreground="#93C5FD" Margin="0,0,0,8"/>

                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="Table1RankInput" Margin="0,0,8,0" ToolTip="Eklenecek konumu gir: 1, 2, 3..."/>
                                    <Button Grid.Column="1" Width="72" Margin="0,0,8,0" Click="AddTable1ItemButton_Click" Content="Ekle"/>
                                    <Button Grid.Column="2" Width="100" Style="{StaticResource DangerButtonStyle}" Click="RemoveTable1ItemButton_Click" Content="Seçileni Sil"/>
                                </Grid>

                                <DataGrid Grid.Row="2"
                                          x:Name="Table1Grid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionChanged="Table1Grid_SelectionChanged"
                                          MinWidth="430">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="90"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="130"/>
                                        <DataGridTextColumn Header="By" Binding="{Binding By}" Width="220"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Tablo 2" FontWeight="SemiBold" Foreground="#93C5FD" Margin="0,0,0,8"/>

                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="Table2RankInput" Margin="0,0,8,0" ToolTip="Eklenecek konumu gir: 1, 2, 3..."/>
                                    <Button Grid.Column="1" Width="72" Margin="0,0,8,0" Click="AddTable2ItemButton_Click" Content="Ekle"/>
                                    <Button Grid.Column="2" Width="100" Style="{StaticResource DangerButtonStyle}" Click="RemoveTable2ItemButton_Click" Content="Seçileni Sil"/>
                                </Grid>

                                <DataGrid Grid.Row="2"
                                          x:Name="Table2Grid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionChanged="Table2Grid_SelectionChanged"
                                          MinWidth="430">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="90"/>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="130"/>
                                        <DataGridTextColumn Header="By" Binding="{Binding By}" Width="220"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*"/>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10" Margin="0,0,10,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Segment detayları" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DataGrid Grid.Row="1"
                              x:Name="SegmentsGrid"
                              AutoGenerateColumns="False"
                              CanUserSortColumns="False"
                              SelectionChanged="SegmentsGrid_SelectionChanged"
                              MinWidth="980">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Alan" Binding="{Binding CellName}" Width="85" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Renk" Width="55">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="22" Height="22"
                                                CornerRadius="5"
                                                BorderBrush="#64748B"
                                                BorderThickness="1"
                                                Background="{Binding Color, Converter={StaticResource CssColorToBrushConverter}}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color, UpdateSourceTrigger=PropertyChanged}" Width="145"/>
                            <DataGridTextColumn Header="BgColor" Binding="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" Width="145"/>
                            <DataGridTextColumn Header="Text" Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="260"/>
                            <DataGridTextColumn Header="Weight" Binding="{Binding FontWeight, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                            <DataGridTemplateColumn Header="Style" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FontStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValuePath="Content"
                                                  SelectedValue="{Binding FontStyle, UpdateSourceTrigger=PropertyChanged}">
                                            <ComboBoxItem Content="normal"/>
                                            <ComboBoxItem Content="italic"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Decoration" Binding="{Binding TextDecoration, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="FontSize" Binding="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                            <DataGridTextColumn Header="FontFamily" Binding="{Binding FontFamily, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                            <DataGridTextColumn Header="Class" Binding="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                            <DataGridTextColumn Header="Tag" Binding="{Binding Tag, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10" Margin="0,0,10,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Seçili segment düzenleyici" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock x:Name="SelectedSegmentInfoText"
                               Grid.Row="1"
                               Text="Bir segment seç"
                               Foreground="{StaticResource SubtleForegroundBrush}"
                               Margin="0,0,0,10"/>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Style" Margin="0,0,0,4"/>
                            <ComboBox x:Name="SegmentStyleComboBox"
                                      SelectionChanged="SegmentStyleComboBox_SelectionChanged">
                                <ComboBoxItem Content="normal"/>
                                <ComboBoxItem Content="italic"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Renk önizleme" Margin="0,0,0,4"/>
                            <Border x:Name="SelectedColorPreviewBorder"
                                    Height="36"
                                    Cursor="Hand"
                                    CornerRadius="6"
                                    BorderBrush="#475569"
                                    BorderThickness="1"
                                    Background="Transparent"
                                    ToolTip="Tıkla, renk skalası açılsın"
                                    MouseLeftButtonUp="SelectedColorPreviewBorder_MouseLeftButtonUp"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3" Background="#0B1220" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="RGB düzenleme" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#93C5FD"/>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="R" Margin="0,0,0,4"/>
                                    <TextBox x:Name="RedTextBox"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="G" Margin="0,0,0,4"/>
                                    <TextBox x:Name="GreenTextBox"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="BlueTextBox"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" VerticalAlignment="Bottom">
                                    <Button x:Name="ApplyRgbButton"
                                            Width="100"
                                            Height="34"
                                            Click="ApplyRgbButton_Click"
                                            Content="RGB Uygula"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="4" Text="Renk tablosu" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#93C5FD" VerticalAlignment="Top"/>
                    <DataGrid Grid.Row="4"
                              x:Name="ColorPaletteGrid"
                              Margin="0,28,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionChanged="ColorPaletteGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="20" Height="20" CornerRadius="4" BorderBrush="#475569" BorderThickness="1"
                                                Background="{Binding CssColor, Converter={StaticResource CssColorToBrushConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="RGB" Binding="{Binding RgbText}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ham JSON" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1"
                             x:Name="JsonTextBox"
                             FontFamily="Consolas"
                             FontSize="13"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Background="#0B1220" Foreground="{StaticResource ForegroundBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Margin="0,12,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Hazır"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
