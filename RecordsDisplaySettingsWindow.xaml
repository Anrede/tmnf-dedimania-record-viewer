<Window x:Class="TmnfDedimaniaScraper.RecordsDisplaySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Show Records Settings"
        Width="520"
        Height="560"
        MinWidth="500"
        MinHeight="420"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True"
        Background="#0F172A"
        Foreground="#E5E7EB"
        Icon="pack://application:,,,/Assets/f1_app_icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#253244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
        </Style>

        <Style x:Key="CompactTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="RangeComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource CompactComboBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="74"/>
        </Style>


        <Style x:Key="PaddingSideTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource CompactTextBoxStyle}">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Width" Value="42"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="74"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SectionTabButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Display settings" FontSize="18" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="TextSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Text" Click="TextSectionButton_Click"/>
            <Button x:Name="LayoutSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Layout" Click="LayoutSectionButton_Click"/>
            <Button x:Name="PaddingSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Padding" Click="PaddingSectionButton_Click"/>
            <Button x:Name="BackgroundSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Background" Click="BackgroundSectionButton_Click"/>
            <Button x:Name="ColorSectionButton" Style="{StaticResource SectionTabButtonStyle}" Content="Color" Click="ColorSectionButton_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Border x:Name="TextSectionBorder" Style="{StaticResource CardStyle}">
                    <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Text Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Record count" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="ShowCountTextBox" Grid.Row="0" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" TextChanged="ShowCountTextBox_TextChanged" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Text="Title size" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="TitleSizeTextBox" Grid.Row="2" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="4" Text="Text size" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="FontSizeTextBox" Grid.Row="4" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="6" Text="Text weight" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="FontWeightComboBox" Grid.Row="6" Grid.Column="1" Width="120" Style="{StaticResource CompactComboBoxStyle}" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Normal"/>
                                    <ComboBoxItem Content="Bold"/>
                                </ComboBox>

                                <TextBlock Grid.Row="8" Text="Transform anims" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox x:Name="TransformAnimationComboBox" Grid.Row="8" Grid.Column="1" Width="140" Style="{StaticResource CompactComboBoxStyle}" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <Border x:Name="LayoutSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Position" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="X" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Y" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="WindowLeftTextBox" Grid.Row="2" Grid.Column="0" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="WindowTopTextBox" Grid.Row="2" Grid.Column="2" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Size" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Width" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Height" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="WindowWidthTextBox" Grid.Row="2" Grid.Column="0" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="WindowHeightTextBox" Grid.Row="2" Grid.Column="2" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Spacing" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Title-&gt;Text" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Text-&gt;Text" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="TitleTextSpacingTextBox" Grid.Row="2" Grid.Column="0" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="VerticalSpacingTextBox" Grid.Row="2" Grid.Column="2" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Rank-&gt;Time" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Time-&gt;By" Foreground="#CBD5E1" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="RankTimeSpacingTextBox" Grid.Row="6" Grid.Column="0" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                    <TextBox x:Name="TimeBySpacingTextBox" Grid.Row="6" Grid.Column="2" Width="84" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <TextBlock Foreground="#94A3B8" TextWrapping="Wrap">
                                Records window position uses the monitor's top-left corner as X=0 and Y=0.
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="PaddingSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Padding Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="3" Text="Left" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="Right" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="7" Text="Top" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="9" Text="Bottom" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Text padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="TextPaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="TextPaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="TextPaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="TextPaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="TextPaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Color padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="BackgroundColorPaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="BackgroundColorPaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="BackgroundColorPaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="BackgroundColorPaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="BackgroundColorPaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Frame padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="FramePaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="FramePaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="FramePaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="FramePaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="FramePaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Image padding" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
                                    <CheckBox x:Name="ImagePaddingSyncCheckBox" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" IsChecked="True" Checked="PaddingSyncCheckBox_Changed" Unchecked="PaddingSyncCheckBox_Changed" Margin="0,0,0,0"/>
                                    <TextBox x:Name="ImagePaddingLeftTextBox" Grid.Column="3" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="ImagePaddingRightTextBox" Grid.Column="5" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="ImagePaddingTopTextBox" Grid.Column="7" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                    <TextBox x:Name="ImagePaddingBottomTextBox" Grid.Column="9" Style="{StaticResource PaddingSideTextBoxStyle}" HorizontalAlignment="Left" TextChanged="PaddingSideTextBox_TextChanged"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <TextBlock Foreground="#94A3B8" TextWrapping="Wrap">
                                These paddings now work as Left, Right, Top, and Bottom values. When the checkbox is checked, editing one box applies the same value to all four sides. Frame padding still accepts negative values so the frame can grow beyond the container.
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="BackgroundSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Color" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Background color" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="BackgroundColorTextBox" Width="160" Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,8,0"/>
                                        <Button x:Name="PickBackgroundColorButton" Width="72" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickBackgroundColorButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Background opacity" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BackgroundOpacityTextBox" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Border radius" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BorderRadiusTextBox" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Image" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Background image" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="BuiltInBackgroundComboBox" Grid.Column="1" Width="160" Style="{StaticResource CompactComboBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Custom image" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="CustomBackgroundPathTextBox" Width="160" Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,8,0"/>
                                        <Button x:Name="BrowseBackgroundButton" Width="72" Style="{StaticResource PrimaryButtonStyle}" Content="Browse" Click="BrowseBackgroundButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Background opacity" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BackgroundImageOpacityTextBox" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Border radius" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="BackgroundImageBorderRadiusTextBox" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Frame" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="BuiltInFrameComboBox" Grid.Column="1" Width="160" Style="{StaticResource CompactComboBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Custom frame" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="CustomFramePathTextBox" Width="160" Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,8,0"/>
                                        <Button x:Name="BrowseFrameButton" Width="72" Style="{StaticResource PrimaryButtonStyle}" Content="Browse" Click="BrowseFrameButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Frame opacity" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="FrameOpacityTextBox" Grid.Column="1" Width="80" Style="{StaticResource CompactTextBoxStyle}" HorizontalAlignment="Left"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="ColorSectionBorder" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Rank &amp; Time Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Table" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="Table1TabButton" Style="{StaticResource ToggleButtonStyle}" Content="Table 1" Click="Table1TabButton_Click"/>
                                        <Button x:Name="Table2TabButton" Style="{StaticResource ToggleButtonStyle}" Margin="0" Content="Table 2" Click="Table2TabButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Item" Style="{StaticResource FieldLabelStyle}"/>
                                    <Grid Grid.Column="1" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="74"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="74"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RankItemTabButton" Grid.Column="0" Style="{StaticResource ToggleButtonStyle}" Margin="0" Content="Rank" Click="RankItemTabButton_Click"/>
                                        <Button x:Name="TimeItemTabButton" Grid.Column="2" Style="{StaticResource ToggleButtonStyle}" Margin="0" Content="Time" Click="TimeItemTabButton_Click"/>
                                    </Grid>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Record slot" Style="{StaticResource FieldLabelStyle}"/>
                                    <Grid Grid.Column="1" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="74"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="74"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="StartSlotComboBox" Grid.Column="0" Style="{StaticResource RangeComboBoxStyle}" SelectionChanged="StartSlotComboBox_SelectionChanged"/>
                                        <ComboBox x:Name="EndSlotComboBox" Grid.Column="2" Style="{StaticResource RangeComboBoxStyle}" SelectionChanged="EndSlotComboBox_SelectionChanged"/>
                                    </Grid>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="SelectedColorTextBox" Width="160" Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,8,0" TextChanged="SelectedColorTextBox_TextChanged"/>
                                        <Button x:Name="PickSelectedColorButton" Width="56" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickSelectedColorButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Other Text Settings" FontSize="15" FontWeight="SemiBold" Foreground="#F8FAFC" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Text" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="TitleColorTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Title" Click="TitleColorTabButton_Click"/>
                                        <Button x:Name="MapLabelColorTabButton" Style="{StaticResource ToggleButtonStyle}" Content="Map:" Click="MapLabelColorTabButton_Click"/>
                                        <Button x:Name="MapNameColorTabButton" Style="{StaticResource ToggleButtonStyle}" Margin="0" Content="Name" Click="MapNameColorTabButton_Click"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="DisplayElementColorTextBox" Width="160" Style="{StaticResource CompactTextBoxStyle}" Margin="0,0,8,0" TextChanged="DisplayElementColorTextBox_TextChanged"/>
                                        <Button x:Name="PickDisplayElementColorButton" Width="56" Style="{StaticResource PrimaryButtonStyle}" Content="Pick" Click="PickDisplayElementColorButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ApplyButton" Style="{StaticResource PrimaryButtonStyle}" Width="78" Margin="0,0,8,0" Content="Apply" Click="ApplyButton_Click"/>
            <Button x:Name="CloseButton" Style="{StaticResource PrimaryButtonStyle}" Width="78" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
